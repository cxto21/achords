{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent State Schema",
  "description": "Schema for per-agent state in .achords/agents/<agent_id>/state.json",
  "type": "object",
  "required": ["agent_id", "has_messages"],
  "properties": {
    "agent_id": {
      "type": "string",
      "description": "Unique agent identifier"
    },
    "has_messages": {
      "type": "integer",
      "enum": [0, 1],
      "description": "Inbox flag: 1 if agent has pending messages"
    },
    "last_activity": {
      "type": "string",
      "format": "date-time",
      "description": "Last action timestamp"
    },
    "active_claims": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of active claim IDs"
    },
    "metadata": {
      "type": "object",
      "description": "Optional state metadata"
    }
  }
}
